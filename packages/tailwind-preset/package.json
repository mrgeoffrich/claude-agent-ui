{
  "name": "@mrgeoffrich/claude-agent-ui-tailwind-preset",
  "version": "0.1.0",
  "description": "Optional default Tailwind styles for @mrgeoffrich/claude-agent-ui-react components",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mrgeoffrich/claude-agent-ui.git",
    "directory": "packages/tailwind-preset"
  },
  "homepage": "https://github.com/mrgeoffrich/claude-agent-ui#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/styles.css dist/styles.css",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "sideEffects": ["*.css"]
}

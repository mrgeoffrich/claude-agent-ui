{
  "name": "claude-agent-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable React UI for Claude Agent SDK message streams",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter ./packages/* build",
    "dev": "pnpm -r --parallel --filter ./packages/* dev",
    "typecheck": "pnpm -r --filter ./packages/* typecheck",
    "clean": "pnpm -r --filter ./packages/* clean",
    "bump": "node scripts/bump-version.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
